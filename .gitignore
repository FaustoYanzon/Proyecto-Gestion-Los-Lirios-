# ── Secrets ──────────────────────────────────────────────────────────────────
# NEVER commit real environment files. Only .env.example belongs in git.
.env
.env.*
!.env.example
*/.env
**/.env
!**/.env.example

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
venv312/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ── Node / frontend / mobile ─────────────────────────────────────────────────
node_modules/
.next/
dist/
build/
.expo/

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── Misc build artifacts seen in tree ────────────────────────────────────────
uvicorn_out.txt

# ── Database backups (contain real data, never commit) ────────────────────────
pg_backups/
