# ── Los Lirios API — environment template ────────────────────────────────────
# Copy to backend/.env and fill in real values. NEVER commit the real .env.

# development | staging | production
# In production the app refuses to start with a weak SECRET_KEY or a "*" CORS origin.
ENVIRONMENT=development

# PostgreSQL (async driver). Example:
# postgresql+asyncpg://user:password@localhost:5432/los_lirios
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/los_lirios

# JWT signing key. Generate a strong one (do NOT reuse the dev value in prod):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-a-strong-64-byte-value

ALGORITHM=HS256
# Access token lifetime in minutes (480 = 8h). No refresh token yet, so keep it
# reasonable; shorter is safer if a token leaks.
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Comma-separated list of allowed browser origins for CORS.
# Prod example: https://app.losliriossa.com,https://admin.losliriossa.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Per-IP throttle for /auth/login and /auth/change-password (slowapi syntax).
LOGIN_RATE_LIMIT=10/minute

# Force-enable interactive docs. Leave unset: docs are on outside production,
# off in production. Set to true only if you deliberately want /docs in prod.
# DOCS_ENABLED=false

# ── Bootstrap super-admin (used only by `python -m app.core.seed`) ───────────
# Required to seed the first admin. Generate the password:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
SUPER_ADMIN_EMAIL=admin@losliriossa.com
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Fausto
